rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // User documents — readable/writable by anyone (fake-money, no auth)
    match /users/{userId} {
      allow read, write: if true;

      // Bets subcollection
      match /bets/{betId} {
        allow read, write: if true;
      }

      // Shop inventory
      match /inventory/{itemId} {
        allow read, write: if true;
      }
    }

    // Bracket games — publicly readable, written only by Cloud Functions
    match /bracket_games/{gameId} {
      allow read: if true;
      allow write: if false;
    }

    // Activity feed
    match /feed/{feedId} {
      allow read, write: if true;
    }

    // Multiplayer blackjack tables
    match /mp_tables/{tableId} {
      allow read, write: if true;
    }

    // SPAM! runs directly through Firestore transactions in the client
    match /spam_matches/{matchId} {
      allow read, write: if true;
    }

    // Queue docs are client-managed
    match /spam_queue/{queueId} {
      allow read, write: if true;
    }


    // Home page poll + custom suggestions
    match /site_polls/{pollId} {
      allow read, write: if true;

      match /custom_suggestions/{suggestionId} {
        allow read, write: if true;
      }
    }

    // Live event leaderboard entries
    match /live_event_entries/{entryId} {
      allow read, write: if true;
    }
  }
}
